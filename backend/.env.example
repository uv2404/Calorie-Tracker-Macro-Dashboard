# ----------------------------------------------------------------------------
# Backend environment variables
# Copy this file to `.env` and adjust the values as needed.
# ----------------------------------------------------------------------------

# Port the Express server listens on
PORT=5000

# MongoDB connection string.
# Local MongoDB:        mongodb://127.0.0.1:27017/calorie-tracker
# MongoDB Atlas (cloud): mongodb+srv://<user>:<password>@<cluster>.mongodb.net/calorie-tracker
MONGO_URI=mongodb://127.0.0.1:27017/calorie-tracker

# Origin allowed by CORS (the frontend dev server URL)
CLIENT_URL=http://localhost:5173
